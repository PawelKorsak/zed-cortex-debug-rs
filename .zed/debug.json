// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "CodeLLDB",
    "label": "cargo test -p zed_cortex_debug_rs --all-targets",
    "build": {
      "label": "cargo test -p zed_cortex_debug_rs --all-targets",
      "command": "cargo",
      "args": [
        "test",
        "--package",
        "zed_cortex_debug_rs",
        "--all-targets",
        "--no-run",
      ],
      "env": {
        "RUSTC_TOOLCHAIN": "/home/pawel/.rustup/toolchains/stable-x86_64-unknown-linux-gnu",
      },
      "cwd": "/home/pawel/git/zed-cortex-debug-rs",
      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "tags": [],
      "shell": "system",
      "show_summary": false,
      "show_command": false,
    },
    "sourceLanguages": ["rust"],
  },
  {
    "adapter": "cortex-debug-rs",
    "label": "This is label",
    "programBinary": "/path/to/binary",
    "tcp_connection": { "host": "127.0.0.1", "port": 2147, "timeout": 5 },
  },
]
